{
  "name": "@mostajs/payment",
  "version": "0.1.0",
  "description": "Payment module for @mostajs — Stripe checkout, multi-method (card, transfer, cash), multi-currency",
  "author": "Dr Hamid MADANI <drmdh@msn.com>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "stripe": "^17.0.0"
  },
  "peerDependencies": {
    "@mostajs/orm": ">=1.8.0",
    "react": ">=18.0.0",
    "next": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "next": { "optional": true }
  },
  "devDependencies": {
    "@mostajs/orm": "^1.8.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/apolocine/mosta-payment"
  },
  "keywords": [
    "mostajs",
    "payment",
    "stripe",
    "checkout",
    "multi-currency",
    "orm"
  ]
}
